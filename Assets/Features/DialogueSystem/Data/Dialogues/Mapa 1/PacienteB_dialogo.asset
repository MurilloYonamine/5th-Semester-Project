  lines:
  - speaker: {fileID: 11400000, guid: cc50f151f660c944eb25bc7012e2c7cb, type: 2}
    text: "Srs Ellie Estou morrendo de fome\u2026"
  - speaker: {fileID: 11400000, guid: cc50f151f660c944eb25bc7012e2c7cb, type: 2}
    text: Tem frutas em todos os lugares!
  - speaker: {fileID: 11400000, guid: cc50f151f660c944eb25bc7012e2c7cb, type: 2}
    text: "Fresca na sua cabe\xE7a doutora hahahaha."
  - speaker: {fileID: 11400000, guid: cc50f151f660c944eb25bc7012e2c7cb, type: 2}
    text: "Mas voc\xEA ser\xE1 a \xFAltima, eu prometo!"

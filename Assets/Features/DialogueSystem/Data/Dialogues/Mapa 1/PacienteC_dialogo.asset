  lines:
  - speaker: {fileID: 11400000, guid: 6e0cb24cb54eee344a544a15cabe4569, type: 2}
    text: Bom dia Ellie!
  - speaker: {fileID: 11400000, guid: 6e0cb24cb54eee344a544a15cabe4569, type: 2}
    text: "Voc\xEAs est\xE3o deslumbrante e hoje\u2026"
  - speaker: {fileID: 11400000, guid: 6e0cb24cb54eee344a544a15cabe4569, type: 2}
    text: "Olha n\xE3o quero parecer louca\u2026 "
  - speaker: {fileID: 11400000, guid: 6e0cb24cb54eee344a544a15cabe4569, type: 2}
    text: "Mas eu juro que vi algo no jardim ontem \xE0 noite"

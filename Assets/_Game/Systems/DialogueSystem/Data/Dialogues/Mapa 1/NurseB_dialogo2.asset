  lines:
  - speaker: {fileID: 11400000, guid: 575b1768cf1e2b44f982abe736320c2e, type: 2}
    text: Obrigado Ellie.
  - speaker: {fileID: 11400000, guid: 575b1768cf1e2b44f982abe736320c2e, type: 2}
    text: "O dia est\xE1 acabando."
  - speaker: {fileID: 11400000, guid: 575b1768cf1e2b44f982abe736320c2e, type: 2}
    text: "N\xE3o esque\xE7a pegar sua d\xE1diva e visitar o ninho l\xE1 fora."
  - speaker: {fileID: 11400000, guid: b60ce40db908516409635937f35dddff, type: 2}
    text: "Infelizmente \xE9 s\xF3 isso guys!"
  - speaker: {fileID: 11400000, guid: b60ce40db908516409635937f35dddff, type: 2}
    text: "Queremos entregar algo muito maior na pr\xF3xima vez!"
  - speaker: {fileID: 11400000, guid: b60ce40db908516409635937f35dddff, type: 2}
    text: "N\xE3o se esque\xE7a do nosso jogo!"
  - speaker: {fileID: 11400000, guid: b60ce40db908516409635937f35dddff, type: 2}
    text: Podem fechar o jogo e fazer o forms!

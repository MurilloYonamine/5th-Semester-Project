  lines:
  - speaker: {fileID: 11400000, guid: ff199b110109aae428f5691bdc778ae9, type: 2}
    text: Hum?!
  - speaker: {fileID: 11400000, guid: ff199b110109aae428f5691bdc778ae9, type: 2}
    text: "S\xF3 estava s\xF3 pensando no que o paciente do lado me falou\u2026"
  - speaker: {fileID: 11400000, guid: ff199b110109aae428f5691bdc778ae9, type: 2}
    text: "O qu\xE3o estranho \xE9 os barulhos..."
